<!-- Single robot stable ball-control test. -->

<root BTCPP_format="4">
    <include path="./subtrees/subtree_cam_find_and_track_ball.xml" />
    <include path="./subtrees/subtree_find_ball.xml" />

    <BehaviorTree ID="MainTree">
        <Sequence name="root">
            <ReactiveSequence>
                <SubTree ID="CamFindAndTrackBall" _autoremap="true" _while="control_state>=2" />
                <Sequence _while="control_state==3">
                    <Sequence _while="!ball_location_known">
                        <PlaySound sound="search" />
                        <SubTree ID="FindBall" _autoremap="true" />
                    </Sequence>
                    <Sequence _while="ball_location_known">
                        <CalcKickDir cross_threshold="0.2" />
                        <SingleRobotDecide decision_out="{decision}" decision_in="{decision}"
                                           chase_threshold="0.9"
                                           kick_range="0.7"
                                           kick_theta_range="0.22"
                                           kick_dir_tolerance="0.28"
                                           ball_y_tolerance="0.18" />
                        <SubTree ID="FindBall" _autoremap="true" _while="decision == 'find'" />
                        <Chase _while="decision == 'chase'"
                               vx_limit="0.55"
                               vy_limit="0.25"
                               vtheta_limit="0.8"
                               dist="0.45"
                               safe_dist="0.65" />
                        <Adjust _while="decision == 'adjust'"
                                turn_threshold="0.3"
                                range="0.45"
                                vx_limit="0.25"
                                vy_limit="0.22"
                                vtheta_limit="0.8"
                                vtheta_factor="1.2"
                                tangential_speed_far="0.22"
                                tangential_speed_near="0.08"
                                near_threshold="0.55"
                                no_turn_threshold="0.06"
                                turn_first_threshold="0.25" />
                        <Kick _while="decision == 'kick'"
                              speed_limit="0.38"
                              min_msec_kick="500"
                              msecs_stablize="500"
                              align_during_kick="true"
                              align_vtheta_factor="0.9"
                              align_vtheta_limit="0.35" />
                    </Sequence>
                </Sequence>
            </ReactiveSequence>
        </Sequence>
    </BehaviorTree>
</root>
