<!-- 摄像头跟踪球 -->

<root BTCPP_format="4" >
   <BehaviorTree ID="FindBall">
      <ReactiveFallback name="root">
         <ScriptCondition code="ball_location_known || tm_ball_pos_reliable" />
         <ReactiveSequence>
            <GoBackInField />
            <Parallel success_count="1" failure_count="2">
               <CamLissajousScan yaw_amplitude="1.012" pitch_center="-0.253" pitch_amplitude="0.567" cycle_msec="1800" />
               <RobotFindBall vyaw_limit="1.2" transition_vx="0.25" />
            </Parallel>
         </ReactiveSequence>
         <ReactiveSequence>
            <GoToReadyPosition vx_limit="0.7" />
            <Sleep msec="2000" />
         </ReactiveSequence>
      </ReactiveFallback>
   </BehaviorTree>
</root>
